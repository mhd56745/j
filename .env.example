# ============================================
# IPTV Panel - Environment Configuration
# ============================================
APP_NAME="IPTV Panel"
APP_ENV=local
APP_KEY=base64:CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iptv_panel
DB_USERNAME=iptv_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis / Cache
CACHE_DRIVER=file
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Streaming Configuration
RTMP_SERVER=localhost
RTMP_PORT=1935
HLS_PATH=/app/storage/app/hls
STREAM_KEY_LENGTH=16
HLS_FRAGMENT_DURATION=2
HLS_PLAYLIST_LENGTH=3
MAX_CONCURRENT_STREAMS=100
STREAM_TIMEOUT=3600

# Admin
ADMIN_EMAIL=admin@iptv.local
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# API
API_RATE_LIMIT=60
API_VERSION=v1

# Cloud66 (auto-populated on deploy)
# C66_URL=
# MYSQL_ADDRESS=
# MYSQL_DATABASE=
# MYSQL_USERNAME=
# MYSQL_PASSWORD=