{
  "name": "iptv-restream-server",
  "version": "2.0.0",
  "description": "Advanced IPTV Restreaming Server with Nginx Proxy - Optimized for Low VPS / Koyeb",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init-db": "node scripts/init-db.js",
    "health-check": "node scripts/health-checker.js",
    "restream:start": "node scripts/restream-manager.js",
    "restream:stop": "node scripts/restream-manager.js stop"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^11.0.0",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "axios": "^1.6.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
